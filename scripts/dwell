#!/usr/bin/env bash
# Dwell CLI — Linux / macOS launch helper.
# Auto-installs Temurin JDK 21 to ~/jdks/ if missing, then runs the requested mode.
#
# Usage:
#   ./scripts/dwell show       # build current source, pause daemon, then open dashboard
#   ./scripts/dwell daemon     # run as tray daemon (dashboard appears after idle)
#   ./scripts/dwell config     # open dashboard with Settings pre-opened
#   ./scripts/dwell dev        # hot-reload dev mode
#   ./scripts/dwell install    # symlink this script into ~/.local/bin so `dwell` works anywhere
#   ./scripts/dwell uninstall  # remove the symlink (does not touch ~/.screensaver)
#   ./scripts/dwell status     # show whether Dwell is running + which JDK / settings it uses
#   ./scripts/dwell help       # show this help
#
# Windows: use scripts\dwell.cmd instead.

set -euo pipefail

# --- Resolve project root (parent of this script's directory) ----------------
# Follow the installed symlink so `dwell show` can run from ~/.local/bin.
SCRIPT_PATH="${BASH_SOURCE[0]}"
while [ -L "$SCRIPT_PATH" ]; do
    SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_PATH")" && pwd)"
    TARGET="$(readlink "$SCRIPT_PATH")"
    case "$TARGET" in
        /*) SCRIPT_PATH="$TARGET" ;;
        *) SCRIPT_PATH="$SCRIPT_DIR/$TARGET" ;;
    esac
done
HERE="$(cd -P "$(dirname "$SCRIPT_PATH")" && pwd)"
ROOT="$(cd "$HERE/.." && pwd)"
cd "$ROOT"

# --- JDK 21 detection / auto-install -----------------------------------------
detect_java21() {
    if [ -n "${JAVA_HOME:-}" ] && [ -x "$JAVA_HOME/bin/java" ]; then
        local v
        v=$("$JAVA_HOME/bin/java" -version 2>&1 | head -1 | sed -nE 's/.*version "([0-9]+)\..*/\1/p')
        if [ "${v:-0}" -ge 21 ] 2>/dev/null; then echo "$JAVA_HOME"; return 0; fi
    fi
    local d
    for d in "$HOME/jdks/jdk-21"* /usr/lib/jvm/java-21-* /usr/lib/jvm/jdk-21* /opt/jdk-21*; do
        if [ -x "$d/bin/java" ]; then echo "$d"; return 0; fi
    done
    return 1
}

install_java21() {
    local arch os
    case "$(uname -m)" in
        x86_64|amd64) arch="x64" ;;
        aarch64|arm64) arch="aarch64" ;;
        *) echo "✗ Unsupported architecture: $(uname -m)" >&2; return 1 ;;
    esac
    case "$(uname -s)" in
        Linux)   os="linux" ;;
        Darwin)  os="mac" ;;
        *) echo "✗ Unsupported OS for auto-install: $(uname -s). Set JAVA_HOME manually." >&2; return 1 ;;
    esac
    local url="https://api.adoptium.net/v3/binary/latest/21/ga/${os}/${arch}/jdk/hotspot/normal/eclipse"
    local jdks="$HOME/jdks"
    local archive="$jdks/temurin21.tar.gz"
    mkdir -p "$jdks"
    echo "▶ Installing Temurin JDK 21 to $jdks (~200MB, one-time)…" >&2
    curl -fL --progress-bar -o "$archive" "$url" >&2 || { echo "✗ Download failed." >&2; return 1; }
    if [ "$os" = "mac" ]; then
        tar -xzf "$archive" -C "$jdks"
        local mac_jdk
        mac_jdk=$(find "$jdks" -maxdepth 4 -type d -name "Home" -path "*Contents*" 2>/dev/null | head -1)
        [ -n "$mac_jdk" ] && ln -sfn "$mac_jdk" "$jdks/jdk-21"
    else
        tar -xzf "$archive" -C "$jdks"
    fi
    rm -f "$archive"
    local installed
    installed=$(detect_java21) || { echo "✗ Extracted but JDK still not found under $jdks." >&2; return 1; }
    echo "✓ JDK 21 installed at $installed" >&2
    echo "$installed"
}

bootstrap_java() {
    local detected
    if detected=$(detect_java21); then
        export JAVA_HOME="$detected"
    else
        detected=$(install_java21) || exit 1
        export JAVA_HOME="$detected"
    fi
    export PATH="$JAVA_HOME/bin:$PATH"
}

first_build_hint() {
    [ -d "composeApp/build/libs" ] || echo "▶ First build — fetching dependencies (~1-2 min on a fast connection)."
}

cheatsheet() {
    cat <<'EOF'
  M       cycle mode (Cinematic → Ambient → Console)
  V       cycle variant
  Esc     hide to tray
  Ctrl+Alt+Space  show from tray (Windows)
  Ctrl+,  Settings    F1 / ?  Help    Ctrl+Q  quit
EOF
}

usage() {
    cat <<'EOF'
Dwell — screensaver-with-widgets

Usage: ./scripts/dwell <command>

Commands:
  show       Build current source, pause the registered daemon, then open the dashboard.
  daemon     Run as a tray daemon (dashboard appears after idle timeout).
  config     Open the dashboard with Settings pre-opened.
  dev        Run with Compose Hot Reload; skips daemon/tray/idle plumbing.
  build      Compile (no launch) — handy for CI / verifying changes.

  install    Symlink this script into ~/.local/bin so you can type `dwell show` anywhere.
  uninstall  Remove the symlink (does not touch ~/.screensaver).
  register   Register Dwell to run at login (autostart + systemd user unit on Linux,
             LaunchAgent on macOS).
  unregister Remove the autostart / LaunchAgent (settings stay).
  status     Show whether Dwell is running + which JDK / settings file is in use.
  version    Print the current version + git commit + branch.
  help       Show this help.

First run will auto-install JDK 21 to ~/jdks/ and download Gradle dependencies.
EOF
}

ensure_linux_desktop_entry() {
    [ "$(uname -s)" = "Linux" ] || return 0
    local applications desktop_file class_alias_file icon_dir icon_name icon_file
    icon_name="dwell-real"
    icon_dir="$HOME/.local/share/icons/hicolor/512x512/apps"
    icon_file="$icon_dir/$icon_name.png"
    applications="$HOME/.local/share/applications"
    desktop_file="$applications/dwell.desktop"
    class_alias_file="$applications/Dwell.desktop"
    mkdir -p "$applications" "$icon_dir"
    cp "$ROOT/composeApp/desktopAppIcons/LinuxIcon.png" "$icon_file"
    rm -f "$applications/MainKt.desktop" "$applications/mainkt.desktop" \
          "$applications/MainKt.MainKt.desktop" "$applications/mainkt.mainkt.desktop"
    if command -v gtk-update-icon-cache >/dev/null 2>&1; then
        gtk-update-icon-cache -q "$HOME/.local/share/icons/hicolor" 2>/dev/null || true
    fi
    cat > "$desktop_file" <<DESKTOP
[Desktop Entry]
Type=Application
Name=Dwell
Comment=Idle-triggered desktop dashboard
Exec=$ROOT/scripts/dwell show
Icon=$icon_name
Terminal=false
Categories=Utility;
StartupNotify=true
StartupWMClass=Dwell
DESKTOP
    cp "$desktop_file" "$class_alias_file"
}

import_linux_session_environment() {
    [ "$(uname -s)" = "Linux" ] || return 0
    command -v systemctl >/dev/null 2>&1 || return 0
    systemctl --user import-environment \
        DISPLAY WAYLAND_DISPLAY XAUTHORITY XDG_RUNTIME_DIR XDG_SESSION_TYPE \
        XDG_CURRENT_DESKTOP DBUS_SESSION_BUS_ADDRESS 2>/dev/null || true
    if command -v dbus-update-activation-environment >/dev/null 2>&1; then
        dbus-update-activation-environment --systemd \
            DISPLAY WAYLAND_DISPLAY XAUTHORITY XDG_RUNTIME_DIR XDG_SESSION_TYPE \
            XDG_CURRENT_DESKTOP DBUS_SESSION_BUS_ADDRESS 2>/dev/null || true
    fi
}

stop_linux_dwell_daemon_apps() {
    [ "$(uname -s)" = "Linux" ] || return 0
    command -v pkill >/dev/null 2>&1 || return 0
    pkill -TERM -f ' Dwell --daemon$' 2>/dev/null || true
}

SHOW_RESTART_DAEMON=0

pause_daemon_for_show() {
    SHOW_RESTART_DAEMON=0
    case "$(uname -s)" in
        Linux)
            if command -v systemctl >/dev/null 2>&1 && \
               systemctl --user is-active --quiet dwell.service 2>/dev/null; then
                SHOW_RESTART_DAEMON=1
                systemctl --user stop dwell.service 2>/dev/null || true
                echo "Dwell — temporarily stopped background daemon for this show session."
            fi
            stop_linux_dwell_daemon_apps
            ;;
        Darwin)
            local plist="$HOME/Library/LaunchAgents/dev.dwell.daemon.plist"
            if [ -f "$plist" ] && command -v launchctl >/dev/null 2>&1; then
                if launchctl print gui/$(id -u)/dev.dwell.daemon >/dev/null 2>&1; then
                    SHOW_RESTART_DAEMON=1
                    launchctl unload "$plist" 2>/dev/null || true
                    echo "Dwell — temporarily stopped background daemon for this show session."
                fi
            fi
            ;;
    esac
}

restore_paused_daemon() {
    [ "${SHOW_RESTART_DAEMON:-0}" = "1" ] || return 0
    SHOW_RESTART_DAEMON=0
    case "$(uname -s)" in
        Linux)
            if command -v systemctl >/dev/null 2>&1; then
                import_linux_session_environment
                systemctl --user start dwell.service 2>/dev/null || true
            fi
            ;;
        Darwin)
            local plist="$HOME/Library/LaunchAgents/dev.dwell.daemon.plist"
            if [ -f "$plist" ] && command -v launchctl >/dev/null 2>&1; then
                launchctl load "$plist" 2>/dev/null || true
            fi
            ;;
    esac
}

# --- Subcommand dispatch -----------------------------------------------------
cmd="${1:-help}"

case "$cmd" in
    show)
        bootstrap_java; ensure_linux_desktop_entry; first_build_hint
        pause_daemon_for_show
        trap restore_paused_daemon EXIT
        echo "Dwell — opening dashboard."
        cheatsheet; echo
        if ./gradlew --no-daemon :composeApp:run --args="--show" --console=plain; then
            show_status=0
        else
            show_status=$?
        fi
        trap - EXIT
        restore_paused_daemon
        exit "$show_status"
        ;;
    daemon)
        bootstrap_java; ensure_linux_desktop_entry; first_build_hint
        echo "Dwell — starting tray daemon. Look for the icon in your system tray."
        echo "  Dashboard auto-opens after the idle timeout (Settings → Triggers)."
        echo
        exec ./gradlew --no-daemon :composeApp:run --args="--daemon" --console=plain
        ;;
    config)
        bootstrap_java; ensure_linux_desktop_entry; first_build_hint
        echo "Dwell — opening dashboard with Settings."
        echo "  Tip: add a WeatherAPI key to enable the weather widget."
        echo
        exec ./gradlew --no-daemon :composeApp:run --args="/c" --console=plain
        ;;
    dev)
        bootstrap_java; first_build_hint
        echo "Dwell — Compose Hot Reload dev mode."
        echo
        exec ./gradlew --no-configuration-cache :composeApp:runHot --console=plain
        ;;
    build)
        bootstrap_java; first_build_hint
        echo "Dwell — compiling…"
        exec ./gradlew :composeApp:compileKotlinJvm :composeApp:compileTestKotlinJvm --console=plain
        ;;
    autostart)
        case "$(uname -s)" in
            Linux)
                ensure_linux_desktop_entry
                import_linux_session_environment
                if command -v systemctl >/dev/null 2>&1 && [ -f "$HOME/.config/systemd/user/dwell.service" ]; then
                    systemctl --user daemon-reload 2>/dev/null || true
                    systemctl --user stop dwell.service 2>/dev/null || true
                    stop_linux_dwell_daemon_apps
                    if systemctl --user start dwell.service 2>/dev/null; then
                        exit 0
                    fi
                fi
                exec "$ROOT/scripts/dwell" daemon
                ;;
            *)
                exec "$ROOT/scripts/dwell" daemon
                ;;
        esac
        ;;
    register)
        # Register Dwell to run as a tray daemon at login.
        # Linux: writes ~/.config/autostart/dwell.desktop + ~/.config/systemd/user/dwell.service.
        # macOS: writes ~/Library/LaunchAgents/dev.dwell.daemon.plist and loads it.
        case "$(uname -s)" in
            Linux)
                ensure_linux_desktop_entry
                autostart="$HOME/.config/autostart"
                systemd_user="$HOME/.config/systemd/user"
                mkdir -p "$autostart" "$systemd_user"
                cat > "$autostart/dwell.desktop" <<DESKTOP
[Desktop Entry]
Type=Application
Name=Dwell
Comment=Idle-triggered screensaver dashboard
Exec=$ROOT/scripts/dwell autostart
Icon=dwell-real
X-GNOME-Autostart-enabled=true
StartupNotify=true
StartupWMClass=Dwell
NoDisplay=false
DESKTOP
                cat > "$systemd_user/dwell.service" <<UNIT
[Unit]
Description=Dwell screensaver daemon
After=graphical-session.target
PartOf=graphical-session.target

[Service]
ExecStart=$ROOT/scripts/dwell daemon
Restart=on-failure
RestartSec=5

[Install]
WantedBy=graphical-session.target
UNIT
                echo "✓ Wrote $autostart/dwell.desktop"
                echo "✓ Wrote $systemd_user/dwell.service"
                if command -v systemctl >/dev/null 2>&1; then
                    import_linux_session_environment
                    systemctl --user daemon-reload 2>/dev/null || true
                    systemctl --user disable dwell.service 2>/dev/null || true
                    systemctl --user stop dwell.service 2>/dev/null || true
                    stop_linux_dwell_daemon_apps
                    if systemctl --user enable dwell.service 2>/dev/null && \
                       systemctl --user start dwell.service 2>/dev/null; then
                        echo "✓ Enabled + started dwell.service (systemd user)"
                    else
                        echo "  Could not start dwell.service automatically. Run manually:"
                        echo "    systemctl --user enable dwell.service && systemctl --user start dwell.service"
                    fi
                fi
                ;;
            Darwin)
                la="$HOME/Library/LaunchAgents"
                mkdir -p "$la"
                cat > "$la/dev.dwell.daemon.plist" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key><string>dev.dwell.daemon</string>
  <key>ProgramArguments</key>
  <array>
    <string>$ROOT/scripts/dwell</string>
    <string>daemon</string>
  </array>
  <key>RunAtLoad</key><true/>
  <key>KeepAlive</key><true/>
  <key>WorkingDirectory</key><string>$ROOT</string>
</dict>
</plist>
PLIST
                launchctl unload "$la/dev.dwell.daemon.plist" 2>/dev/null || true
                launchctl load "$la/dev.dwell.daemon.plist"
                echo "✓ Loaded LaunchAgent dev.dwell.daemon (autostarts at login)"
                ;;
            *)
                echo "✗ $cmd: this OS isn't supported (yet). On Windows use scripts\\dwell.cmd register." >&2
                exit 1 ;;
        esac
        echo
        echo "  To stop and unregister later, run: ./scripts/dwell unregister"
        ;;
    unregister)
        case "$(uname -s)" in
            Linux)
                if command -v systemctl >/dev/null 2>&1; then
                    systemctl --user disable --now dwell.service 2>/dev/null || true
                fi
                rm -f "$HOME/.config/autostart/dwell.desktop"
                rm -f "$HOME/.config/systemd/user/dwell.service"
                if command -v systemctl >/dev/null 2>&1; then
                    systemctl --user daemon-reload 2>/dev/null || true
                fi
                echo "✓ Removed autostart + systemd user unit (settings at ~/.screensaver untouched)."
                ;;
            Darwin)
                la="$HOME/Library/LaunchAgents/dev.dwell.daemon.plist"
                if [ -f "$la" ]; then
                    launchctl unload "$la" 2>/dev/null || true
                    rm -f "$la"
                    echo "✓ Unloaded + removed LaunchAgent"
                else
                    echo "  No LaunchAgent found."
                fi
                ;;
            *)
                echo "✗ $cmd: this OS isn't supported (yet)." >&2
                exit 1 ;;
        esac
        ;;
    install)
        target_dir="${DWELL_BIN_DIR:-$HOME/.local/bin}"
        mkdir -p "$target_dir"
        target="$target_dir/dwell"
        ln -sfn "$HERE/dwell" "$target"
        ensure_linux_desktop_entry
        echo "✓ Linked: $target → $HERE/dwell"
        case ":$PATH:" in
            *":$target_dir:"*) echo "  $target_dir is on your PATH. Try: dwell show" ;;
            *) echo "  $target_dir is NOT on your PATH. Add this to your shell rc:"
               echo "    export PATH=\"$target_dir:\$PATH\"" ;;
        esac
        ;;
    uninstall)
        target_dir="${DWELL_BIN_DIR:-$HOME/.local/bin}"
        target="$target_dir/dwell"
        if [ -L "$target" ]; then
            rm -f "$target"
            echo "✓ Removed: $target"
        else
            echo "  No symlink at $target — nothing to remove."
        fi
        echo "  (Your settings + widget data at ~/.screensaver remain untouched.)"
        ;;
    status)
        echo "Dwell — status"
        echo "  Project root: $ROOT"
        if pid=$(pgrep -f '[D]well|[M]ainKt' 2>/dev/null | head -1); then
            echo "  Running: PID $pid"
        else
            echo "  Running: no"
        fi
        if detected=$(detect_java21 2>/dev/null); then
            echo "  JDK 21:  $detected"
        else
            echo "  JDK 21:  not detected (run any command to auto-install)"
        fi
        if [ -f "$HOME/.screensaver/settings.json" ]; then
            echo "  Settings: $HOME/.screensaver/settings.json"
        else
            echo "  Settings: not yet written (first run hasn't completed)"
        fi
        if [ -d "$HOME/.screensaver/widgets" ]; then
            count=$(find "$HOME/.screensaver/widgets" -maxdepth 2 \( -name '*.jar' -o -name 'widget.yaml' \) 2>/dev/null | wc -l | tr -d ' ')
            echo "  Third-party widgets: $count installed at ~/.screensaver/widgets/"
        fi
        ;;
    version|--version|-v)
        # Print version + short git commit. Reads from the same source the
        # Gradle build pulls into BuildInfo.kt.
        ver="1.0.0"  # KEEP IN SYNC with appVersion in composeApp/build.gradle.kts
        commit=$(git -C "$ROOT" rev-parse --short HEAD 2>/dev/null || echo "unknown")
        branch=$(git -C "$ROOT" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "unknown")
        echo "Dwell $ver"
        echo "  commit: $commit"
        echo "  branch: $branch"
        ;;
    help|-h|--help)
        usage
        ;;
    *)
        echo "Unknown command: $cmd" >&2
        echo
        usage
        exit 2
        ;;
esac
